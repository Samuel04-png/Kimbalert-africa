rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function signedIn() {
      return request.auth != null;
    }
    
    match /children/{childId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn(); 
    }

    match /guardians/{guardianId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
